# ============================================================
# Production environment template
# Copy to .env.prod and fill in real values (.env.prod is gitignored)
#
# Generate a strong Postgres password with:
#   openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
# ============================================================

# Domain (used by nginx envsubst + finish.sh for certbot)
DOMAIN=analytis.zyntra.company
ACME_EMAIL=techeasy376@gmail.com

# Postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_32_CHARS

# Application — use the SAME password as POSTGRES_PASSWORD above
ANALYTIS_DATABASE_URL=postgresql+psycopg://analytis:CHANGE_ME_STRONG_RANDOM_32_CHARS@postgres:5432/analytis
ANALYTIS_API_KEY=dariokrugerjunior1999

# Logging (json for prod log aggregation)
ANALYTIS_LOG_LEVEL=INFO
ANALYTIS_LOG_FORMAT=json

# External APIs (paste from local .env)
ANALYTIS_FOOTBALL_DATA_API_KEY=
ANALYTIS_ELO_RATINGS_URL=http://www.eloratings.net/World.tsv
ANALYTIS_THE_ODDS_API_KEY=
ANALYTIS_THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ANALYTIS_OPENAI_API_KEY=
ANALYTIS_OPENAI_MODEL=gpt-4o-mini

# Auto-ingest scheduler
ANALYTIS_AUTO_INGEST_ENABLED=true
ANALYTIS_AUTO_INGEST_COMPETITION=2000
ANALYTIS_AUTO_INGEST_SEASON=2026
ANALYTIS_AUTO_INGEST_INTERVAL_SECONDS=120

# Web Push VAPID keys (generate via: uv run analytis push generate-vapid-keys)
ANALYTIS_VAPID_PRIVATE_KEY=
ANALYTIS_VAPID_PUBLIC_KEY=
ANALYTIS_VAPID_SUBJECT=mailto:techeasy376@gmail.com
